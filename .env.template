# ASCR local/server environment template.
# Copy to .env locally if desired. Never commit real .env files or real keys.

# Remote API judges. Leave unset unless running scripts/judge/*_gpt.py or Gemini/OFOX jobs.
OFOX_API_KEY=
OFOX_BASE_URL=https://api.ofox.ai/v1
ASCR_TEACHER_MODEL=bailian/qwen3.7-plus
ASCR_TEACHER_QUALITY_MAX_TOKENS=2048
ASCR_TEACHER_LOCALIZATION_MAX_TOKENS=2048
ASCR_TEACHER_JSON_REPAIR_RETRIES=1

# Local model/checkpoint overrides.
QWEN_MODEL_PATH=models/qwen3.5-9b
LUMINA_REPO=third_party/Lumina-DiMOO
LUMINA_MODEL_PATH=models/lumina-dimoo
MMADA_REPO=external/MMaDA
SHOWO_REPO_DIR=external/Show-o

# Hugging Face/cache behavior.
HF_HOME=.hf_home
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
TOKENIZERS_PARALLELISM=false

# Cluster virtualenv names. Override these per server if your envs live elsewhere.
ASCR_ENV_QWEN=.venv-qwen36
ASCR_ENV_LUMINA=.venv-lumina
ASCR_ENV_MMADA=.venv-mmada
ASCR_ENV_SHOWO=.venv-qwen36

# Run sharding/output defaults.
OUT_ROOT=outputs/ascr_run
PROMPT_LIMIT=
NUM_WORKERS=8
NUM_PAIRS=4
NODE_INDEX=0
NODE_COUNT=1
